#pragma once

// Copy to src/secrets.h (gitignored) and fill in. Identical fleet-wide.
// MQTT credentials: use the dedicated fleet user "nodes" (NOT the bridge's own
// credential). This keeps fleet and bridge credentials independent so either can be
// rotated without affecting the other. The "nodes" account is provisioned in the
// lumi stack's Mosquitto passwd (from the MQTT_NODES_PASSWORD secret) and restricted
// to the "lumi/#" topic namespace via the Mosquitto ACL. MQTT_PASSWORD here must
// match the MQTT_NODES_PASSWORD value used by the lumi deployment.
#define WIFI_SSID     "your-ssid"
#define WIFI_PASSWORD "your-password"
#define MQTT_HOST     "192.168.1.10"
#define MQTT_PORT     1883
#define MQTT_USER     "nodes"
#define MQTT_PASSWORD "your-nodes-mqtt-password"
