#pragma once

// Copy to src/secrets.h (gitignored) and fill in. Identical fleet-wide.
// MQTT credentials: use the dedicated fleet user "lumi-fleet" (NOT the bridge's own
// credential). This keeps fleet and bridge credentials independent so either can be
// rotated without affecting the other. Create "lumi-fleet" in Mosquitto's passwd file
// and restrict it to the "lumi/#" topic namespace via a Mosquitto ACL.
#define WIFI_SSID     "your-ssid"
#define WIFI_PASSWORD "your-password"
#define MQTT_HOST     "192.168.1.10"
#define MQTT_PORT     1883
#define MQTT_USER     "lumi-fleet"
#define MQTT_PASSWORD "your-fleet-mqtt-password"
